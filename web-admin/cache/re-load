#!/bin/bash
DIR="$(dirname "$0")"
ROOT="$(dirname $DIR)"
ETC="$ROOT/etc"
CACHE="$ROOT/cache"

source $CACHE/versions.sh

echo ">>> Reload ${#YVERS_VERSIONS[@]} versions ..."
for VER in ${YVERS_VERSIONS[@]}; do
  echo ">>>> ${VER} ..."
  $ETC/version-load $VER
  echo "--------------------------------------------------------------------"
done
